  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "electron .",
    "electron:pack": "electron-packager . ThreeKingdomsFish --platform=win32 --arch=x64 --out=release --overwrite --prune=false --ignore=\"^/src($|/)\" --ignore=\"^/public($|/)\" --ignore=\"^/release($|/)\" --ignore=\"^/node_modules($|/)\" --ignore=\"^/\\.git($|/)\" --ignore=\"\\.map$\" --ignore=\"^/package-lock\\.json$\" --ignore=\"\\.bat$\""
  },
  "dependencies": {
    "three": "^0.165.0",
    "three.quarks": "^0.15.7"
